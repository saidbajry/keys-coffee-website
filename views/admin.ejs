<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin - Key's Coffee</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-stone-50 font-sans text-stone-800 overflow-x-hidden">

    <nav class="bg-white border-b border-stone-200 px-4 sm:px-8 py-4 flex justify-between items-center shadow-sm">
        <h1 class="font-serif text-lg sm:text-xl tracking-wider font-bold text-stone-900">Key's Coffee Control Panel
        </h1>
        <div class="flex items-center gap-4 sm:gap-6">
            <a href="/" target="_blank" class="text-xs sm:text-sm text-stone-500 hover:text-stone-900 transition">Lihat
                Website ↗</a>
            <a href="/logout"
                class="text-xs sm:text-sm bg-red-50 text-red-600 px-3 py-1.5 rounded hover:bg-red-100 transition font-medium">Logout</a>
        </div>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8 mt-6">

        <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-stone-100">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-base font-bold text-stone-800 font-serif">Grafik Pendapatan Bulanan (2026)</h3>
                <span class="text-xs text-stone-400">Real-time DB</span>
            </div>
            <div class="h-[260px] relative">
                <canvas id="salesChart"></canvas>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-stone-100 flex flex-col justify-between">
            <div>
                <h3 class="text-base font-bold text-stone-800 font-serif mb-2">Laporan Pembukuan</h3>
                <p class="text-xs text-stone-500 leading-relaxed mb-4">
                    Unduh seluruh riwayat rekaman data pembelian produk pelanggan yang masuk ke database sistem selama
                    30 hari terakhir ke dalam format spreadsheet Microsoft Excel.
                </p>
            </div>
            <div>
                <a href="/admin/download-report"
                    class="block text-center w-full bg-emerald-600 text-white font-semibold text-xs uppercase tracking-wider py-3.5 rounded-xl hover:bg-emerald-700 transition duration-300 shadow-md">
                    📊 Unduh Laporan Excel (.xlsx)
                </a>
            </div>
        </div>

    </div>

    <div class="max-w-7xl mx-auto p-4 sm:p-8 grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8">

        <div class="bg-white p-5 sm:p-6 rounded-xl border border-stone-200 shadow-sm h-fit">
            <h3 class="font-serif text-lg mb-4 text-stone-900 font-semibold">Tambah Koleksi Baru</h3>

            <form action="/admin/add-product" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="block text-xs uppercase tracking-wider text-stone-500 mb-1 font-medium">Nama
                        Produk</label>
                    <input type="text" name="name" placeholder="Contoh: Signature Blend v2" required
                        class="w-full border border-stone-300 rounded p-2 text-sm focus:outline-none focus:border-stone-600 transition">
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-wider text-stone-500 mb-1 font-medium">Harga (Angka
                        Saja)</label>
                    <input type="text" name="price" placeholder="Contoh: 350000" required
                        class="w-full border border-stone-300 rounded p-2 text-sm focus:outline-none focus:border-stone-600 transition">
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-wider text-stone-500 mb-1 font-medium">Deskripsi
                        Singkat Teks</label>
                    <textarea name="description" rows="2" placeholder="Contoh: Rich chocolate and caramel notes."
                        required
                        class="w-full border border-stone-300 rounded p-2 text-sm focus:outline-none focus:border-stone-600 transition resize-none"></textarea>
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-wider text-stone-500 mb-1 font-medium">Upload Foto
                        Produk</label>
                    <input type="file" name="product_image" accept="image/*" id="imageInput" required
                        class="w-full text-xs text-stone-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-stone-100 file:text-stone-700 hover:file:bg-stone-200 cursor-pointer">
                </div>

                <div
                    class="border border-dashed border-stone-300 p-2 rounded flex justify-center items-center bg-stone-50 min-h-[100px]">
                    <img id="previewImage" src="#" alt="Preview" class="hidden max-h-32 object-cover rounded shadow-sm">
                    <span id="previewText" class="text-xs text-stone-400">Belum ada foto dipilih</span>
                </div>

                <button type="submit"
                    class="w-full bg-stone-900 text-white py-2.5 rounded text-sm uppercase tracking-widest font-semibold hover:bg-stone-800 transition-colors shadow-sm">
                    Simpan Ke Toko
                </button>
            </form>
        </div>

        <div class="lg:col-span-2 bg-white p-5 sm:p-6 rounded-xl border border-stone-200 shadow-sm">

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                <div class="bg-stone-900 text-stone-100 p-4 rounded-lg shadow-sm">
                    <p class="text-[10px] uppercase tracking-widest text-stone-400 font-medium">Total Live Items</p>
                    <p class="text-2xl font-serif font-bold mt-1">
                        <%= products.length %>
                    </p>
                </div>
                <div class="bg-stone-100 text-stone-800 p-4 rounded-lg border border-stone-200 shadow-sm">
                    <p class="text-[10px] uppercase tracking-widest text-stone-500 font-medium">Registered Customers</p>
                    <p class="text-2xl font-serif font-bold mt-1 text-stone-900">
                        <%= users.length %>
                    </p>
                </div>
                <div class="bg-amber-50 text-amber-900 p-4 rounded-lg border border-amber-200 shadow-sm">
                    <p class="text-[10px] uppercase tracking-widest text-amber-600 font-medium">Pesan & Kotak Saran</p>
                    <p class="text-2xl font-serif font-bold mt-1 text-amber-950">
                        <%= messages.length %>
                    </p>
                </div>
            </div>

            <div class="flex border-b border-stone-200 mb-6 text-xs sm:text-sm overflow-x-auto no-scrollbar">
                <button id="btnTabProduct" onclick="switchContentTab('product')"
                    class="py-2.5 px-4 font-medium border-b-2 border-stone-900 text-stone-900 focus:outline-none transition whitespace-nowrap">
                    Manajemen Menu (<%= products.length %>)
                </button>
                <button id="btnTabUser" onclick="switchContentTab('user')"
                    class="py-2.5 px-4 font-medium border-b-2 border-transparent text-stone-400 hover:text-stone-900 focus:outline-none transition whitespace-nowrap">
                    Daftar Pelanggan (<%= users.length %>)
                </button>
                <button id="btnTabMessage" onclick="switchContentTab('message')"
                    class="py-2.5 px-4 font-medium border-b-2 border-transparent text-stone-400 hover:text-stone-900 focus:outline-none transition whitespace-nowrap">
                    Kotak Saran (<%= messages.length %>)
                </button>
            </div>

            <div id="sectionProductTable" class="block overflow-x-auto">
                <table class="w-full text-left text-sm border-collapse min-w-[500px]">
                    <thead>
                        <tr class="border-b border-stone-200 text-stone-400 text-xs uppercase tracking-wider">
                            <th class="pb-3 w-16">Foto</th>
                            <th class="pb-3">Nama Menu</th>
                            <th class="pb-3">Deskripsi</th>
                            <th class="pb-3">Harga</th>
                            <th class="pb-3 text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-stone-100">
                        <% products.forEach(item=> { %>
                            <tr class="hover:bg-stone-50/60 transition-colors">
                                <td class="py-3">
                                    <img src="<%= item.img %>" alt=""
                                        class="w-11 h-11 object-cover rounded bg-stone-100 border border-stone-200">
                                </td>
                                <td class="py-3 font-medium text-stone-950 whitespace-nowrap">
                                    <%= item.name %>
                                </td>
                                <td class="py-3 text-stone-500 text-xs max-w-[180px] truncate">
                                    <%= item.description %>
                                </td>
                                <td class="py-3 text-stone-600 font-medium whitespace-nowrap">
                                    <%= item.price %>
                                </td>
                                <td class="py-3 text-right">
                                    <form action="/admin/delete-product/<%= item.id %>" method="POST"
                                        onsubmit="return confirm('Apakah kamu yakin ingin menghapus item ini?')">
                                        <button type="submit"
                                            class="text-xs text-red-500 hover:text-red-700 font-semibold bg-red-50 hover:bg-red-100 px-2.5 py-1 rounded transition">
                                            Hapus
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>

            <div id="sectionUserTable" class="hidden overflow-x-auto">
                <table class="w-full text-left text-sm border-collapse min-w-[500px]">
                    <thead>
                        <tr class="border-b border-stone-200 text-stone-400 text-xs uppercase tracking-wider">
                            <th class="pb-3 w-16">ID</th>
                            <th class="pb-3">Nama Lengkap</th>
                            <th class="pb-3">Username</th>
                            <th class="pb-3 text-right">Tanggal Bergabung</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-stone-100">
                        <% if (users.length===0) { %>
                            <tr>
                                <td colspan="4" class="py-8 text-center text-stone-400 italic text-sm">Belum ada
                                    customer yang terdaftar.</td>
                            </tr>
                            <% } else { %>
                                <% users.forEach(user=> { %>
                                    <tr class="hover:bg-stone-50/60 transition-colors">
                                        <td class="py-3.5 text-stone-400 font-mono text-xs">#<%= user.id %>
                                        </td>
                                        <td class="py-3.5 font-medium text-stone-900">
                                            <%= user.name %>
                                        </td>
                                        <td class="py-3.5">
                                            <span class="bg-stone-100 text-stone-700 px-2 py-0.5 rounded text-xs">@<%=
                                                    user.username %></span>
                                        </td>
                                        <td class="py-3.5 text-right text-stone-500 text-xs">
                                            <%= new Date(user.created_at).toLocaleDateString('id-ID', { day: 'numeric' ,
                                                month: 'long' , year: 'numeric' }) %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <div id="sectionMessageTable" class="hidden overflow-x-auto">
                <table class="w-full text-left text-sm border-collapse min-w-[600px]">
                    <thead>
                        <tr class="border-b border-stone-200 text-stone-400 text-xs uppercase tracking-wider">
                            <th class="pb-3">Pengirim</th>
                            <th class="pb-3">Kontak Info</th>
                            <th class="pb-3">Isi Pesan / Saran</th>
                            <th class="pb-3 text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-stone-100">
                        <% if (messages.length===0) { %>
                            <tr>
                                <td colspan="4" class="py-8 text-center text-stone-400 italic text-sm">Belum ada pesan
                                    saran yang masuk.</td>
                            </tr>
                            <% } else { %>
                                <% messages.forEach(msg=> { %>
                                    <tr class="hover:bg-stone-50/60 transition-colors">
                                        <td class="py-3.5">
                                            <p class="font-medium text-stone-900">
                                                <%= msg.name %>
                                            </p>
                                            <span class="text-[10px] text-stone-400 block mt-0.5">
                                                <%= new Date(msg.created_at).toLocaleString('id-ID') %>
                                            </span>
                                        </td>
                                        <td class="py-3.5 text-xs text-stone-600 leading-normal">
                                            <p class="truncate max-w-[150px]">✉️ <%= msg.email %>
                                            </p>
                                            <p class="mt-0.5">📞 <%= msg.phone %>
                                            </p>
                                        </td>
                                        <td class="py-3.5 text-xs text-stone-700 max-w-[240px] break-words">
                                            <%= msg.message %>
                                        </td>
                                        <td class="py-3.5 text-right">
                                            <form action="/admin/delete-message/<%= msg.id %>" method="POST"
                                                onsubmit="return confirm('Apakah kamu yakin ingin menghapus pesan saran ini?')">
                                                <button type="submit"
                                                    class="text-xs text-red-500 hover:text-red-700 font-medium bg-red-50 hover:bg-red-100 px-2.5 py-1 rounded transition">
                                                    Hapus
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <script>
        // Handle Live Preview File Gambar input
        document.getElementById('imageInput').onchange = evt => {
            const [file] = evt.target.files;
            if (file) {
                document.getElementById('previewImage').src = URL.createObjectURL(file);
                document.getElementById('previewImage').classList.remove('hidden');
                document.getElementById('previewText').classList.add('hidden');
            }
        }

        // Handle Penukaran 3 Tab Konten Manajemen (Produk, User, Message) secara Akurat
        function switchContentTab(target) {
            const btnProd = document.getElementById('btnTabProduct');
            const btnUser = document.getElementById('btnTabUser');
            const btnMsg = document.getElementById('btnTabMessage');

            const secProd = document.getElementById('sectionProductTable');
            const secUser = document.getElementById('sectionUserTable');
            const secMsg = document.getElementById('sectionMessageTable');

            // 1. Reset seluruh desain tombol tab menjadi pudar (transparent)
            const activeClass = "py-2.5 px-4 font-medium border-b-2 border-stone-900 text-stone-900 focus:outline-none transition whitespace-nowrap";
            const inactiveClass = "py-2.5 px-4 font-medium border-b-2 border-transparent text-stone-400 hover:text-stone-900 focus:outline-none transition whitespace-nowrap";

            btnProd.className = inactiveClass;
            btnUser.className = inactiveClass;
            btnMsg.className = inactiveClass;

            // 2. Sembunyikan seluruh container tabel data
            secProd.classList.add('hidden');
            secUser.classList.add('hidden');
            secMsg.classList.add('hidden');

            // 3. Nyalakan tab target yang dipilih user secara dinamis
            if (target === 'user') {
                btnUser.className = activeClass;
                secUser.classList.remove('hidden');
            } else if (target === 'message') {
                btnMsg.className = activeClass;
                secMsg.classList.remove('hidden');
            } else {
                btnProd.className = activeClass;
                secProd.classList.remove('hidden');
            }
        }
    </script>
    <script>
        // Ambil data dari EJS, jika chartData kosong/undefined otomatis gunakan array kosong []
        // Kita bungkus dengan tanda kutip tunggal '' agar jika backend mengirim kosong, browser membacanya sebagai string '[]' yang aman di-parse
        const rawData = '<%- typeof chartData !== "undefined" && chartData ? JSON.stringify(chartData) : "[]" %>';
        const databaseData = JSON.parse(rawData || '[]');
        // Pastikan databaseData berbentuk array sebelum melakukan mapping
        const labelsBulan = Array.isArray(databaseData) ? databaseData.map(item => item.bulan) : [];
        const nilaiOmzet = Array.isArray(databaseData) ? databaseData.map(item => item.total) : [];

        const ctx = document.getElementById('salesChart').getContext('2d');

        new Chart(ctx, {
            type: 'bar',
            data: {
                // Cek dengan aman menggunakan logika opsional (?.) atau validasi standar
                labels: (labelsBulan && labelsBulan.length) ? labelsBulan : ['Belum Ada Transaksi'],
                datasets: [{
                    label: 'Total Omzet (Rp)',
                    data: (nilaiOmzet && nilaiOmzet.length) ? nilaiOmzet : [0],
                    backgroundColor: 'rgba(120, 53, 15, 0.85)',
                    borderColor: '#451a03',
                    borderWidth: 1.5,
                    borderRadius: 8,
                    hoverBackgroundColor: '#451a03',
                    hoverBorderColor: '#78350f',
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,

                // --- TRICK UTAMA UTK CONFIG ANIMASI BERGERAK ---
                animations: {
                    y: {
                        duration: 2000,           // Durasi gerakan naik (2 detik)
                        easing: 'easeOutBounce',  // Efek memantul estetik saat sampai di puncak grafik
                        from: 0                   // Grafik bergerak tumbuh mulai dari angka 0 ke atas
                    },
                    opacity: {
                        duration: 1000,
                        easing: 'linear',
                        from: 0,
                        to: 1
                    }
                },

                // Efek transisi halus saat hover mouse
                transitions: {
                    active: {
                        animation: {
                            duration: 400
                        }
                    }
                },

                plugins: {
                    legend: {
                        labels: {
                            font: {
                                family: 'serif',
                                size: 12
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function (value) {
                                return 'Rp ' + value.toLocaleString('id-ID');
                            },
                            font: {
                                size: 11
                            }
                        },
                        grid: {
                            color: 'rgba(0, 0, 0, 0.05)'
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            font: {
                                size: 11,
                                weight: 'bold'
                            }
                        }
                    }
                }
            }
        });
    </script>
</body>

</html>