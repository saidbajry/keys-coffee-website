<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Key's Coffee</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/icon.png">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        html {
            scroll-behavior: smooth;
        }

        @keyframes shimmer {
            100% {
                transform: translateX(100%);
            }
        }
    </style>
</head>

<body class="bg-white text-[#2c1b12] overflow-x-hidden" data-user='<%= user ? JSON.stringify(user) : "null" %>'>

    <div id="qrisModal" class="fixed inset-0 bg-black/70 hidden flex items-center justify-center z-50 p-4">
        <div
            class="bg-[#faf7f2] p-6 rounded-2xl max-w-sm w-full text-center border border-amber-600/20 shadow-2xl flex flex-col items-center">
            <h3 class="text-stone-800 font-bold font-serif text-lg mb-1">E-PO KASIR DIGITAL</h3>
            <p class="text-xs text-stone-500 mb-4">Silakan scan untuk menyelesaikan pembayaran</p>

            <div id="qrcode" class="p-3 bg-white rounded-xl shadow-inner mb-4"></div>

            <div class="w-full bg-amber-700/10 text-amber-900 py-2.5 rounded-xl font-bold text-sm tracking-wide mb-3">
                Total: <span id="qrisTotal">Rp 0</span>
            </div>

            <div id="qrisStatus" class="flex items-center gap-2 text-xs text-amber-700 animate-pulse font-medium mb-2">
                <span class="w-2 h-2 rounded-full bg-amber-700 animate-ping"></span>
                Menunggu verifikasi transaksi...
            </div>
        </div>
    </div>

    <nav class="fixed top-0 left-0 w-full bg-white/90 backdrop-blur-md z-50 shadow-sm border-b border-[#e7ddd3]/30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex justify-between items-center">

            <div class="text-xl sm:text-2xl font-bold text-primary tracking-wide">
                Key's Coffee
            </div>

            <div class="hidden md:flex gap-8 lg:gap-10 text-xs lg:text-sm uppercase tracking-widest items-center">
                <a href="#home" class="nav-link hover:text-gold transition">Home</a>
                <a href="#about" class="nav-link hover:text-gold transition">About</a>
                <a href="#menu" class="nav-link hover:text-gold transition">Menu</a>
                <a href="#product" class="nav-link hover:text-gold transition">Products</a>
                <a href="#contact" class="nav-link hover:text-gold transition">Contact</a>

                <% if (user) { %>
                    <div
                        class="relative flex items-center gap-3 bg-gradient-to-r from-amber-700 via-[#2c1b12] to-amber-950 text-[#faf7f2] px-5 py-2.5 rounded-xl font-semibold border border-amber-600/30 shadow-md">
                        <span class="text-xs tracking-wide">
                            Halo, <strong class="text-gold">
                                <%= user %>
                            </strong>
                        </span>
                        <span class="text-amber-600/50">|</span>
                        <a href="/logout"
                            class="text-[10px] uppercase tracking-widest text-stone-300 hover:text-red-400 transition-colors duration-200">
                            Keluar
                        </a>
                    </div>
                    <% } else { %>
                        <a href="/login"
                            class="relative group overflow-hidden bg-gradient-to-r from-amber-700 via-[#2c1b12] to-amber-950 text-[#faf7f2] px-6 py-2.5 rounded-xl font-semibold tracking-widest text-xs uppercase shadow-md transition-all duration-500 hover:shadow-amber-900/40 hover:shadow-xl hover:-translate-y-0.5 focus:outline-none border border-amber-600/30">
                            <span
                                class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></span>
                            <span class="relative z-10">
                                Login
                            </span>
                        </a>
                        <% } %>
            </div>

            <div class="flex items-center gap-4 sm:gap-5 relative">
                <button id="chatToggle" class="text-lg sm:text-xl hover:text-gold transition focus:outline-none"
                    title="AI Assistant">
                    <i class="fa-solid fa-robot"></i>
                </button>

                <button id="cartToggle"
                    class="relative text-lg sm:text-xl hover:text-gold transition focus:outline-none" title="Open Cart">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span id="cartCount"
                        class="absolute -top-2.5 -right-2.5 bg-primary text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center font-bold">0</span>
                </button>

                <button id="menuMobileBtn" class="block md:hidden text-xl hover:text-gold transition focus:outline-none"
                    onclick="toggleMobileMenu()">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

        </div>

        <div id="mobileMenu"
            class="hidden absolute top-full left-0 w-full bg-white border-b border-stone-200 flex flex-col p-6 gap-4 text-center text-xs uppercase tracking-widest font-semibold md:hidden shadow-lg">
            <a href="#home" onclick="toggleMobileMenu()"
                class="py-2 border-b border-stone-50 hover:text-gold transition">Home</a>
            <a href="#about" onclick="toggleMobileMenu()"
                class="py-2 border-b border-stone-50 hover:text-gold transition">About</a>
            <a href="#menu" onclick="toggleMobileMenu()"
                class="py-2 border-b border-stone-50 hover:text-gold transition">Menu</a>
            <a href="#product" onclick="toggleMobileMenu()"
                class="py-2 border-b border-stone-50 hover:text-gold transition">Products</a>
            <a href="#contact" onclick="toggleMobileMenu()"
                class="py-2 border-b border-stone-50 hover:text-gold transition">Contact</a>
        </div>
    </nav>

    <section id="home" class="min-h-screen bg-cover bg-center relative flex items-center pt-16"
        style="background-image:url('/images/home-3.png')">
        <div class="absolute inset-0 bg-black/30"></div>

        <div class="relative z-10 max-w-7xl mx-auto w-full px-4 sm:px-6 py-12">
            <div
                class="max-w-2xl text-white md:text-[#2c1b12] bg-black/40 md:bg-transparent p-6 sm:p-8 md:p-0 rounded-3xl backdrop-blur-sm md:backdrop-blur-none">
                <p
                    class="uppercase tracking-[4px] sm:tracking-[5px] text-xs sm:text-sm mb-4 sm:mb-5 text-gold font-medium">
                    Dedikasi Rasa Otentik
                </p>
                <h1
                    class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-serif leading-tight mb-6 text-white md:text-primary">
                    Seni Seduh Kopi Pilihan
                </h1>
                <p
                    class="text-sm sm:text-base md:text-lg text-stone-200 md:text-gray-700 leading-relaxed mb-8 sm:mb-10 max-w-xl">
                    Nikmati kenyamanan dari biji kopi berkualitas tinggi yang disangrai sempurna dan diseduh dengan
                    penuh presisi.
                </p>
                <a href="#menu"
                    class="inline-block bg-primary text-white text-xs sm:text-sm uppercase tracking-widest font-bold px-8 sm:px-10 py-4 rounded-xl hover:scale-105 hover:bg-amber-800 transition shadow-lg">
                    Explore Menu
                </a>
            </div>
        </div>
    </section>

    <section id="about" class="py-20 sm:py-24 bg-soft">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
            <div class="w-full order-2 md:order-1">
                <img src="/images/about-1.png" alt="About Us"
                    class="rounded-3xl shadow-2xl w-full object-cover max-h-[450px]">
            </div>
            <div class="space-y-6 order-1 md:order-2">
                <h2 class="text-4xl sm:text-5xl font-serif text-primary">About Key's Coffee</h2>
                <p class="text-sm sm:text-base text-gray-700 leading-relaxed">
                    Berdiri sejak tahun 2025 di jantung skena kopi Jakarta Selatan, tepatnya di Jl. Panglima Polim,
                    Key's Coffee hadir sebagai ruang bagi para pencinta cita rasa kopi otentik. Mengusung dedikasi penuh
                    pada teknik manual brew, kami berkomitmen menyajikan seduhan berkualitas tinggi seperti V-60 ikonik
                    dan Ice Coffee Gula Aren yang disukai semua kalangan. Bagi kami, menyeduh kopi bukan sekadar
                    rutinitas operasional, melainkan sebuah seni menjaga konsistensi kualitas bahan baku terbaik
                    langsung dari supplier roastery tepercaya, dikombinasikan dengan kehangatan pelayanan yang ramah
                    bagi setiap pengunjung.
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8 pt-4">
                    <div class="border-l-2 border-gold pl-4">
                        <h3 class="font-bold text-lg sm:text-xl mb-1.5 text-primary">Manual Brew</h3>
                        <p class="text-xs sm:text-sm text-gray-600">Dedikasi presisi pada setiap tetesan seduhan V-60.
                        </p>
                    </div>
                    <div class="border-l-2 border-gold pl-4">
                        <h3 class="font-bold text-lg sm:text-xl mb-1.5 text-primary">Roastery Supplier</h3>
                        <p class="text-xs sm:text-sm text-gray-600">Bahan baku tepercaya untuk menjaga konsistensi rasa.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="menu" class="py-20 sm:py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <div class="text-center mb-16 sm:mb-20">
                <p class="uppercase tracking-[5px] text-[10px] sm:text-xs text-gold mb-3 font-semibold">Our Daily Brews
                </p>
                <h2 class="text-3xl sm:text-4xl md:text-5xl text-primary font-serif">Coffee & Food Best Seller</h2>
                <div class="w-12 h-[2px] bg-gold/30 mx-auto mt-4"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 lg:gap-x-16 gap-y-12">
                <!-- KATEGORI 01: MANUAL BREW -->
                <div class="space-y-6 sm:space-y-8">
                    <h3
                        class="text-xl sm:text-2xl font-serif text-primary border-b border-gold/20 pb-3 flex items-center gap-3 font-semibold">
                        <span class="text-gold"></span> Manual Brew
                    </h3>

                    <!-- V60 -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="V60" data-price="20000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">V60
                            </h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Seduhan kopi filter
                                manual dengan karakter rasa yang bersih dan jernih.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            20.000</span>
                    </div>

                    <!-- V60+ -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="V60+" data-price="22000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                V60+</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Eksplorasi ekstraksi
                                manual brew dengan intensitas rasa yang lebih bold.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            22.000</span>
                    </div>

                    <!-- Vietnam Drip Susu -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Vietnam Drip Susu" data-price="20000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Vietnam Drip Susu</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Kombinasi klasik
                                tetesan kopi pekat berpadu manisnya susu kental manis pilihan.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            20.000</span>
                    </div>

                    <!-- Vietnam Drip Aren -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Vietnam Drip Aren" data-price="22000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Vietnam Drip Aren</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Seduhan kopi drip
                                tradisional dengan pemanis alami sirup gula aren murni.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            22.000</span>
                    </div>
                </div>

                <!-- KATEGORI 02: NOODLES & RICE -->
                <div class="space-y-6 sm:space-y-8">
                    <h3
                        class="text-xl sm:text-2xl font-serif text-primary border-b border-gold/20 pb-3 flex items-center gap-3 font-semibold">
                        <span class="text-gold"></span> Noodles & Rice
                    </h3>

                    <!-- Spaghetti Original -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Spaghetti Original" data-price="14000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Spaghetti Original</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Pasta klasik lembut
                                bertabur bumbu rempah gurih khas Italia.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            14.000</span>
                    </div>

                    <!-- Spaghetti Chicken Katsu -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Spaghetti Chicken Katsu" data-price="18000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Spaghetti Chicken Katsu</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Sajian pasta lezat
                                lengkap dengan potongan ayam katsu krispi di atasnya.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            18.000</span>
                    </div>

                    <!-- Indomie Goreng / Rebus + Telur -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Indomie Goreng / Rebus + Telur" data-price="10000">
                        <div class="max-w-[70%]">
                            <div class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Indomie Goreng / Rebus + Telur</div>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Mie instan favorit
                                sejuta umat disajikan hangat dengan tambahan telur.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            10.000</span>
                    </div>

                    <!-- Indomie Double + Telur -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Indomie Double + Telur" data-price="20000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Indomie Double + Telur</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Porsi ganda mi instan
                                pilihan dengan paduan telur pas untuk penuntas lapar.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            20.000</span>
                    </div>

                    <!-- Indomie Spesial (Telur + Keju + Sosis) -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Indomie Spesial" data-price="18000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Indomie Spesial</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Kreasi mi premium
                                bertabur keju parut gurih, irisan sosis, dan topping telur.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            18.000</span>
                    </div>

                    <!-- Nasi Putih -->
                    <div class="buy-container flex justify-between items-start group gap-2 cursor-pointer"
                        data-name="Nasi Putih" data-price="4000">
                        <div class="max-w-[70%]">
                            <h4 class="font-bold text-base sm:text-lg text-primary group-hover:text-gold transition">
                                Nasi Putih</h4>
                            <p class="text-xs sm:text-sm text-gray-500 italic mt-0.5 line-clamp-2">Nasi putih pulen
                                berkualitas sebagai pelengkap santapan makan harian.</p>
                        </div>
                        <span
                            class="h-[1px] bg-gray-300 mx-1 grow border-dashed align-bottom self-end mb-2 hidden sm:block"></span>
                        <span class="font-serif font-bold text-base sm:text-lg text-primary whitespace-nowrap">Rp
                            4.000</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="product" class="py-16 sm:py-24 bg-white border-t border-stone-100 select-none">
        <div class="text-center mb-10 sm:mb-16 px-4">
            <p class="uppercase tracking-[4px] text-[10px] text-gold mb-2 font-semibold">Curated Collection</p>
            <h2 class="text-3xl sm:text-4xl md:text-5xl text-primary font-serif">The Key's Products</h2>
            <div class="w-10 h-[1px] bg-gold/40 mx-auto mt-4"></div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
            <% if (products.length===0) { %>
                <div class="text-center py-12 text-stone-400 font-serif italic text-sm">
                    Belum ada koleksi produk yang dipajang di etalase toko.
                </div>
                <% } else { %>

                    <div
                        class="hidden sm:flex flex-nowrap gap-6 overflow-x-auto pb-8 pt-2 scroll-smooth no-scrollbar snap-x snap-mandatory">
                        <% products.forEach(product=> { %>
                            <div
                                class="product-card bg-soft border border-[#e7ddd3]/30 rounded-2xl p-4 flex flex-col justify-between hover:shadow-xl hover:border-stone-300/60 transition duration-300 group flex-shrink-0 w-[280px] snap-start">
                                <div>
                                    <div
                                        class="overflow-hidden rounded-xl mb-4 aspect-square bg-stone-200 shadow-sm relative">
                                        <img src="<%= product.img %>" alt="<%= product.name %>"
                                            class="h-full w-full object-cover group-hover:scale-105 transition duration-500">
                                    </div>
                                    <h3 class="text-lg font-serif text-primary mb-1 truncate">
                                        <%= product.name %>
                                    </h3>
                                    <p class="text-gray-500 text-xs line-clamp-2 min-h-[32px] leading-relaxed">
                                        <%= product.description %>
                                    </p>
                                </div>
                                <div>
                                    <div
                                        class="flex justify-between items-center mb-3 pt-2 border-t border-stone-200/40">
                                        <span class="text-[10px] uppercase tracking-wider text-stone-400">Price</span>
                                        <span class="text-base font-bold text-primary">
                                            <%= product.price %>
                                        </span>
                                    </div>
                                    <div class="buy-container" data-name="<%= product.name %>"
                                        data-price="<%= product.price.replace(/[^0-9]/g, '') %>">
                                        <button
                                            class="buy-btn bg-primary text-white text-[11px] uppercase tracking-widest font-bold py-3 rounded-xl w-full hover:bg-gold transition focus:outline-none">
                                            Buy
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <div class="grid grid-cols-2 gap-3 sm:hidden">
                        <% products.forEach(product=> { %>
                            <div
                                class="product-card bg-soft border border-[#e7ddd3]/20 rounded-xl p-2.5 flex flex-col justify-between group">
                                <div>
                                    <div class="overflow-hidden rounded-lg mb-2.5 aspect-square bg-stone-200 relative">
                                        <img src="<%= product.img %>" alt="<%= product.name %>"
                                            class="h-full w-full object-cover">
                                    </div>
                                    <h3 class="text-sm font-serif text-primary font-bold truncate leading-tight mb-0.5">
                                        <%= product.name %>
                                    </h3>
                                    <p class="text-stone-500 text-[10px] line-clamp-1 min-h-[14px] mb-2">
                                        <%= product.description %>
                                    </p>
                                </div>
                                <div>
                                    <div
                                        class="flex justify-between items-center mb-2 pt-1 border-t border-stone-200/30">
                                        <span class="text-[11px] font-bold text-primary">
                                            <%= product.price %>
                                        </span>
                                    </div>
                                    <div class="buy-container" data-name="<%= product.name %>"
                                        data-price="<%= product.price.replace(/[^0-9]/g, '') %>">
                                        <button
                                            class="buy-btn bg-primary text-white text-[10px] uppercase tracking-wider font-bold py-2 rounded-lg w-full hover:bg-gold transition focus:outline-none">
                                            Buy
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <% } %>
        </div>
    </section>

    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>

    <section id="contact" class="w-full bg-[#faf7f2] py-20 px-4 sm:px-6 md:px-12 text-[#2c1b12]">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-14">
                <p class="tracking-[0.25em] uppercase text-[#8b7a5f] text-[10px] sm:text-xs font-semibold mb-3">Hubungi
                    Kami</p>
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-medium leading-tight mb-4">Kunjungi Kedai
                    Kopi Kami</h2>
                <p class="text-[#6d5c52] max-w-2xl mx-auto text-xs sm:text-sm md:text-base tracking-wide">
                    Rasakan kehangatan kopi pilihan dan kenyamanan di setiap sesapan.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">

                <!-- PETA GOOGLE MAPS -->
                <div
                    class="w-full min-h-[300px] sm:min-h-[400px] lg:min-h-[450px] rounded-[24px] overflow-hidden shadow-sm border border-[#e7ddd3]/60 relative">
                    <iframe class="w-full h-full grayscale-[35%] contrast-[105%] sepia-[10%] border-0"
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3964.2009088308714!2d106.80465439999999!3d-6.4962292!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69c3006d167a9d%3A0x2e5be74c6c428991!2sKey's%20Coffe!5e0!3m2!1sid!2sid!4v1779977127620!5m2!1sid!2sid"
                        loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>

                <!-- FORM KONTAK -->
                <div
                    class="bg-[#f5eff6]/40 backdrop-blur-sm rounded-[24px] p-6 sm:p-8 md:p-12 border border-[#e7ddd3]/80 flex flex-col justify-between shadow-sm">

                    <form id="contactForm" class="flex flex-col justify-between h-full space-y-6">
                        <div class="space-y-6">
                            <h3 class="text-xl sm:text-2xl font-serif font-medium mb-2">Mari Bicara Kopi</h3>
                            <p class="text-[#8b7a5f] mb-8 text-xs sm:text-sm leading-relaxed tracking-wide">
                                Bagikan saran, jalin kolaborasi, atau sekadar menyapa kami — kami akan sangat senang
                                mendengar pesan dari Anda.
                            </p>

                            <div class="relative group">
                                <input type="text" id="contactName" name="name" required placeholder=" "
                                    class="peer w-full bg-transparent border-b border-[#c2b6a8] py-2 text-sm focus:outline-none focus:border-[#2c1b12] transition-colors duration-300 placeholder-transparent" />
                                <label for="contactName"
                                    class="absolute left-0 -top-3.5 text-xs text-[#8b7a5f] transition-all duration-300 peer-placeholder-shown:text-sm peer-placeholder-shown:text-[#a39585] peer-placeholder-shown:top-2 peer-focus:-top-3.5 peer-focus:text-xs peer-focus:text-[#2c1b12]">
                                    Nama Anda
                                </label>
                            </div>

                            <div class="relative group">
                                <input type="email" id="contactEmail" name="email" required placeholder=" "
                                    class="peer w-full bg-transparent border-b border-[#c2b6a8] py-2 text-sm focus:outline-none focus:border-[#2c1b12] transition-colors duration-300 placeholder-transparent" />
                                <label for="contactEmail"
                                    class="absolute left-0 -top-3.5 text-xs text-[#8b7a5f] transition-all duration-300 peer-placeholder-shown:text-sm peer-placeholder-shown:text-[#a39585] peer-placeholder-shown:top-2 peer-focus:-top-3.5 peer-focus:text-xs peer-focus:text-[#2c1b12]">
                                    Email Anda
                                </label>
                            </div>

                            <div class="relative group">
                                <input type="tel" id="contactPhone" name="phone" placeholder=" "
                                    class="peer w-full bg-transparent border-b border-[#c2b6a8] py-2 text-sm focus:outline-none focus:border-[#2c1b12] transition-colors duration-300 placeholder-transparent" />
                                <label for="contactPhone"
                                    class="absolute left-0 -top-3.5 text-xs text-[#8b7a5f] transition-all duration-300 peer-placeholder-shown:text-sm peer-placeholder-shown:text-[#a39585] peer-placeholder-shown:top-2 peer-focus:-top-3.5 peer-focus:text-xs peer-focus:text-[#2c1b12]">
                                    Nomor Telepon
                                </label>
                            </div>

                            <div class="relative group">
                                <textarea id="contactMessage" name="message" required placeholder=" " rows="3"
                                    class="peer w-full bg-transparent border-b border-[#c2b6a8] py-2 text-sm focus:outline-none focus:border-[#2c1b12] transition-colors duration-300 placeholder-transparent resize-none"></textarea>
                                <label for="contactMessage"
                                    class="absolute left-0 -top-3.5 text-xs text-[#8b7a5f] transition-all duration-300 peer-placeholder-shown:text-sm peer-placeholder-shown:text-[#a39585] peer-placeholder-shown:top-2 peer-focus:-top-3.5 peer-focus:text-xs peer-focus:text-[#2c1b12]">
                                    Tulis pesan Anda di sini...
                                </label>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit"
                                class="w-full bg-[#2c1b12] text-[#faf7f2] py-3.5 rounded-xl tracking-[0.2em] uppercase text-xs font-semibold hover:bg-[#473124] transition-colors duration-300 shadow-sm focus:outline-none">
                                Kirim Pesan
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </section>

    <div id="cartSidebar"
        class="fixed top-0 right-[-100%] w-full sm:w-[420px] h-screen bg-white shadow-2xl z-50 transition-all duration-500 p-5 sm:p-6 flex flex-col justify-between">
        <div>
            <div class="flex justify-between items-center mb-8 border-b border-stone-100 pb-4">
                <h2 class="text-2xl sm:text-3xl font-bold font-serif text-primary">Your Cart</h2>
                <button id="closeCart" class="text-xl p-2 hover:text-red-500 transition focus:outline-none">✕</button>
            </div>
            <div id="cartItems" class="space-y-4 overflow-y-auto max-h-[calc(100vh-250px)] pr-1"></div>
        </div>

        <div class="border-t border-stone-100 pt-4 bg-white">
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm uppercase tracking-wider text-stone-400 font-medium">Grand Total</span>
                <h3 class="text-xl sm:text-2xl font-bold text-primary font-serif">Rp <span id="cartTotal">0</span></h3>
            </div>
            <button id="checkoutBtn"
                class="w-full bg-primary text-white text-xs uppercase tracking-widest font-bold py-4 rounded-xl hover:bg-gold transition shadow-md focus:outline-none">
                Checkout WhatsApp
            </button>
        </div>
    </div>

    <div id="chatBot"
        class="fixed top-0 right-[-100%] w-full sm:w-[420px] h-screen bg-white shadow-2xl z-50 transition-all duration-500 flex flex-col justify-between">
        <div class="bg-primary text-white p-4 sm:p-5 flex justify-between items-center shadow-md">
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
                <h2 class="text-xl font-serif tracking-wide">Key's AI Coffee</h2>
            </div>
            <button id="closeChat" class="text-lg p-2 hover:text-stone-300 transition focus:outline-none">✕</button>
        </div>

        <div id="chatMessages" class="chat-box flex-1 p-4 sm:p-5 space-y-4 bg-soft overflow-y-auto">
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-stone-100 text-stone-800 text-sm max-w-[90%]">
                Hello Welcome to Key's Coffee. Ask me anything about coffee or our profile.
            </div>
        </div>

        <div class="p-4 border-t border-stone-100 bg-white flex gap-3 items-center">
            <input id="chatInput" type="text" placeholder="Ask about coffee..."
                class="flex-1 border border-stone-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-primary transition">
            <button id="sendChat"
                class="bg-primary text-white text-xs uppercase tracking-widest font-bold px-5 py-3.5 rounded-xl hover:bg-gold transition focus:outline-none">
                Send
            </button>
        </div>
    </div>

    <footer class="bg-primary text-white py-12 text-center px-4 border-t border-white/5">
        <h2 class="text-2xl sm:text-3xl mb-3 font-serif tracking-wide">Key's Coffee</h2>
        <p class="text-stone-400 text-xs sm:text-sm tracking-wider font-light">Artisanal Brewing & Discerning Taste.</p>
        <p class="text-stone-500 text-[10px] uppercase tracking-[0.2em] mt-6">© 2026 Key's Coffee Control System. All
            Rights Reserved.</p>
    </footer>

    <script>
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('hidden');
        }
    </script>
    <script src="/js/app.js"></script>

    <div id="customToast"
        class="fixed bottom-10 left-1/2 -translate-x-1/2 z-50 bg-[#2c1b12] text-[#faf7f2] px-6 py-3 rounded-xl shadow-2xl tracking-wide text-sm font-medium border border-gold/20 opacity-0 pointer-events-none transition-all duration-500 transform translate-y-2">
        <div class="flex items-center gap-3">

            <span id="toastMessage">Pesan Terkirim</span>
        </div>
    </div>
</body>

</html>