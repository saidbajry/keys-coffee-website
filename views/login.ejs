<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Key's Coffee</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: linear-gradient(rgba(44, 27, 18, 0.6), rgba(44, 27, 18, 0.7)), url('/images/home-3.png') no-repeat center center/cover;
        }
    </style>
</head>

<body class="h-screen flex items-center justify-center p-4">

    <div class="bg-white/10 backdrop-blur-md p-8 rounded-2xl border border-white/20 shadow-2xl w-full max-w-md">
        <div class="text-center mb-8">
            <h2 class="text-white text-3xl font-serif tracking-wide">Key's Coffee</h2>
            <p class="text-stone-300 text-xs mt-2 uppercase tracking-widest">Sign in to your account</p>
        </div>

        <div class="flex border-b border-white/10 mb-6 text-sm">
            <button id="tabUser" onclick="switchTab('user')"
                class="w-full py-2 text-center text-white border-b-2 border-white font-medium focus:outline-none transition">
                Customer Login
            </button>
            <button id="tabAdmin" onclick="switchTab('admin')"
                class="w-full py-2 text-center text-stone-400 border-b-2 border-transparent font-medium focus:outline-none transition">
                Admin Portal
            </button>
        </div>

        <% if (error) { %>
            <div class="bg-red-500/20 border border-red-500/40 rounded p-3 mb-4 text-center">
                <p class="text-red-200 text-xs">
                    <%= error %>
                </p>
            </div>
            <% } %>

                <form action="/login" method="POST" class="space-y-5">
                    <input type="hidden" name="role" id="loginRole" value="user">

                    <div>
                        <label
                            class="block text-xs uppercase tracking-widest text-stone-300 mb-1.5 font-medium">Username</label>
                        <input type="text" name="username" placeholder="Enter your username" required
                            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-stone-400 focus:outline-none focus:border-white transition text-sm">
                    </div>

                    <div>
                        <label
                            class="block text-xs uppercase tracking-widest text-stone-300 mb-1.5 font-medium">Password</label>
                        <input type="password" name="password" placeholder="••••••••" required
                            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-stone-400 focus:outline-none focus:border-white transition text-sm">
                    </div>

                    <button type="submit"
                        class="w-full bg-white text-[#2c1b12] py-3.5 rounded-xl text-xs hover:bg-stone-100 transition-all uppercase tracking-widest font-bold mt-2 shadow-lg">
                        Sign In
                    </button>
                </form>

                <div class="text-center mt-4" id="registerPrompt">
                    <p class="text-xs text-stone-300">
                        Belum punya akun? <a href="/register" class="text-white underline font-semibold ml-1">Register
                            di sini</a>
                    </p>
                </div>

                <div class="text-center mt-6">
                    <a href="/" class="text-xs text-stone-300 hover:text-white transition">← Kembali ke Beranda</a>
                </div>
    </div>

    <script>
        function switchTab(role) {
            const tabUser = document.getElementById('tabUser');
            const tabAdmin = document.getElementById('tabAdmin');
            const roleInput = document.getElementById('loginRole');
            const regPrompt = document.getElementById('registerPrompt');

            if (role === 'admin') {
                roleInput.value = 'admin';
                tabAdmin.className = "w-full py-2 text-center text-white border-b-2 border-white font-medium focus:outline-none transition";
                tabUser.className = "w-full py-2 text-center text-stone-400 border-b-2 border-transparent font-medium focus:outline-none transition";
                if (regPrompt) regPrompt.style.display = 'none';
            } else {
                roleInput.value = 'user';
                tabUser.className = "w-full py-2 text-center text-white border-b-2 border-white font-medium focus:outline-none transition";
                tabAdmin.className = "w-full py-2 text-center text-stone-400 border-b-2 border-transparent font-medium focus:outline-none transition";
                if (regPrompt) regPrompt.style.display = 'block';
            }
        }
    </script>
</body>

</html>