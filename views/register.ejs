<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Key's Coffee</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: linear-gradient(rgba(44, 27, 18, 0.6), rgba(44, 27, 18, 0.7)), url('/images/home-3.png') no-repeat center center/cover;
        }
    </style>
</head>

<body class="h-screen flex items-center justify-center p-4">

    <div class="bg-white/10 backdrop-blur-md p-8 rounded-2xl border border-white/20 shadow-2xl w-full max-w-md">
        <div class="text-center mb-6">
            <h2 class="text-white text-3xl font-serif tracking-wide">Key's Coffee</h2>
            <p class="text-stone-300 text-xs mt-2 uppercase tracking-widest">Create your customer account</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-500/20 border border-red-500/40 rounded p-3 mb-4 text-center">
                <p class="text-red-200 text-xs">
                    <%= error %>
                </p>
            </div>
            <% } %>

                <form action="/register" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs uppercase tracking-widest text-stone-300 mb-1 font-medium">Full
                            Name</label>
                        <input type="text" name="name" placeholder="John Doe" required
                            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-white placeholder-stone-400 focus:outline-none focus:border-white transition text-sm">
                    </div>

                    <div>
                        <label
                            class="block text-xs uppercase tracking-widest text-stone-300 mb-1 font-medium">Username</label>
                        <input type="text" name="username" placeholder="johndoe" required
                            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-white placeholder-stone-400 focus:outline-none focus:border-white transition text-sm">
                    </div>

                    <div>
                        <label
                            class="block text-xs uppercase tracking-widest text-stone-300 mb-1 font-medium">Password</label>
                        <input type="password" name="password" placeholder="••••••••" required
                            class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-white placeholder-stone-400 focus:outline-none focus:border-white transition text-sm">
                    </div>

                    <button type="submit"
                        class="w-full bg-white text-[#2c1b12] py-3 rounded-xl text-xs hover:bg-stone-100 transition-all uppercase tracking-widest font-bold mt-2 shadow-lg">
                        Register
                    </button>
                </form>

                <div class="text-center mt-6">
                    <p class="text-xs text-stone-300">Sudah punya akun? <a href="/login"
                            class="text-white underline font-semibold ml-1">Login di sini</a></p>
                </div>
    </div>

</body>

</html>